# بوت القرآن الكريم - إعدادات القناة
# Quran Bot - Channel Configuration

# ============================================
# 1. توكن البوت (من BotFather)
# ============================================
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# ============================================
# 2. معرف القناة (اختر واحداً من الخيارات)
# ============================================

# الخيار 1: استخدام اسم القناة (الأسهل)
# مثال: @quran_verses_channel
CHANNEL_ID=@your_channel_name

# الخيار 2: استخدام المعرف الرقمي (الأدق)
# مثال: -100123456789
# CHANNEL_ID=-100123456789

# ============================================
# 3. إعدادات اختيارية
# ============================================

# مستوى السجلات
LOG_LEVEL=INFO

# الفاصل الزمني بين الآيات (بالدقائق)
VERSE_INTERVAL=15

# ============================================
# ملاحظات مهمة:
# ============================================
# 1. احفظ هذا الملف باسم .env
# 2. أضف التوكن الخاص بك
# 3. أضف معرف القناة الخاص بك
# 4. تأكد من أن البوت مسؤول في القناة
# 5. لا تشارك هذا الملف مع أحد
