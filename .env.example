# بوت تلغرام - متغيرات البيئة
# Telegram Bot Environment Variables

# توكن البوت من BotFather
# Get this from @BotFather on Telegram
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# معرف القناة (اختياري - للإرسال إلى قناة)
# Optional: Channel ID for broadcasting verses
# Format: -100123456789 (negative number)
CHANNEL_ID=

# معرف المستخدم الإداري (اختياري)
# Optional: Admin user ID for special commands
ADMIN_ID=

# مستوى السجلات
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
